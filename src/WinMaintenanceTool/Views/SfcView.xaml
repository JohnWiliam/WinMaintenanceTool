<UserControl x:Class="WinMaintenanceTool.Views.SfcView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="3*" />
        </Grid.ColumnDefinitions>

        <StackPanel Margin="0,0,12,0">
            <TextBlock Text="{Binding Title}" FontSize="24" FontWeight="SemiBold" />
            <TextBlock Text="{Binding Description}" Margin="0,8,0,14" TextWrapping="Wrap" />
            <ItemsControl ItemsSource="{Binding Actions}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <ui:Card Margin="0,0,0,8" Padding="12">
                            <StackPanel>
                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="15" />
                                <TextBlock Text="{Binding Description}" TextWrapping="Wrap" Margin="0,4,0,8" Opacity="0.9" />
                                <Button Content="Executar" Command="{Binding DataContext.RunCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" />
                            </StackPanel>
                        </ui:Card>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>

        <Border Grid.Column="1" Padding="12" Background="#AA0A0A0A" CornerRadius="8">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                <TextBlock Text="{Binding Output}" FontFamily="Consolas" TextWrapping="Wrap" />
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
