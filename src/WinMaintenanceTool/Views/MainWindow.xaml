<ui:FluentWindow x:Class="WinMaintenanceTool.Views.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:vm="clr-namespace:WinMaintenanceTool.ViewModels"
                 xmlns:views="clr-namespace:WinMaintenanceTool.Views"
                 mc:Ignorable="d"
                 Title="{Binding AppTitle}"
                 Width="1120"
                 Height="760"
                 MinWidth="1080"
                 MinHeight="720"
                 ResizeMode="CanResize"
                 WindowStartupLocation="CenterScreen"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica">
    <ui:FluentWindow.Resources>
        <DataTemplate DataType="{x:Type vm:HomeViewModel}">
            <views:HomeView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SfcViewModel}">
            <views:SfcView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:DismViewModel}">
            <views:DismView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
            <views:SettingsView />
        </DataTemplate>
    </ui:FluentWindow.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" LastChildFill="False" Margin="0,0,0,12">
            <TextBlock Text="{Binding AppTitle}" FontSize="22" FontWeight="SemiBold" VerticalAlignment="Center" />
            <Button Content="⌂" Width="36" Height="36" Margin="12,0,0,0" Command="{Binding NavigateHomeCommand}" ToolTip="Home" />
        </DockPanel>

        <ContentControl Grid.Row="1" Content="{Binding CurrentPageViewModel}" />

        <DockPanel Grid.Row="2" Margin="0,12,0,0">
            <Button Content="⚙️" Width="40" Height="40" HorizontalAlignment="Right" Command="{Binding NavigateSettingsCommand}" ToolTip="Settings" />
        </DockPanel>
    </Grid>
</ui:FluentWindow>
