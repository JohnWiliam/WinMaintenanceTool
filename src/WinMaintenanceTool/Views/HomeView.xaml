<UserControl x:Class="WinMaintenanceTool.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="{Binding Title}" FontSize="24" FontWeight="SemiBold" />
            <TextBlock Text="{Binding Subtitle}" Margin="0,6,0,0" TextWrapping="Wrap" Opacity="0.85" />
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,18,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Margin="0,0,8,0"
                    Padding="0"
                    Background="Transparent"
                    BorderThickness="0"
                    HorizontalContentAlignment="Stretch"
                    VerticalContentAlignment="Stretch"
                    AutomationProperties.Name="{Binding OpenSfcLabel}"
                    AutomationProperties.HelpText="{Binding SfcDescription}"
                    Command="{Binding DataContext.NavigateSfcCommand, RelativeSource={RelativeSource AncestorType=Window}}">
                <ui:Card Padding="18" Height="230">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <ui:SymbolIcon Symbol="Home24" FontSize="28" />
                        <StackPanel Grid.Row="1" Margin="0,12,0,0">
                            <TextBlock Text="SFC" FontWeight="SemiBold" FontSize="22" />
                            <TextBlock Text="{Binding SfcDescription}" TextWrapping="Wrap" Margin="0,8,0,0" Opacity="0.9" />
                        </StackPanel>
                        <TextBlock Grid.Row="2" Text="{Binding OpenSfcLabel}" FontWeight="SemiBold" Opacity="0.85" />
                    </Grid>
                </ui:Card>
            </Button>

            <Button Grid.Column="1"
                    Margin="8,0,0,0"
                    Padding="0"
                    Background="Transparent"
                    BorderThickness="0"
                    HorizontalContentAlignment="Stretch"
                    VerticalContentAlignment="Stretch"
                    AutomationProperties.Name="{Binding OpenDismLabel}"
                    AutomationProperties.HelpText="{Binding DismDescription}"
                    Command="{Binding DataContext.NavigateDismCommand, RelativeSource={RelativeSource AncestorType=Window}}">
                <ui:Card Padding="18" Height="230">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <ui:SymbolIcon Symbol="Settings24" FontSize="28" />
                        <StackPanel Grid.Row="1" Margin="0,12,0,0">
                            <TextBlock Text="DISM" FontWeight="SemiBold" FontSize="22" />
                            <TextBlock Text="{Binding DismDescription}" TextWrapping="Wrap" Margin="0,8,0,0" Opacity="0.9" />
                        </StackPanel>
                        <TextBlock Grid.Row="2" Text="{Binding OpenDismLabel}" FontWeight="SemiBold" Opacity="0.85" />
                    </Grid>
                </ui:Card>
            </Button>
        </Grid>
    </Grid>
</UserControl>
