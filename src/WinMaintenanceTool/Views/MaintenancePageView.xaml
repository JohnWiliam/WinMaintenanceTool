<UserControl x:Class="WinMaintenanceTool.Views.MaintenancePageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="2*" />
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="{Binding Title}" FontSize="24" FontWeight="SemiBold" />
                <TextBlock Text="{Binding Description}" Margin="0,8,0,0" TextWrapping="Wrap" Opacity="0.85" />
                <TextBlock Text="{Binding ActionCountLabel}" Margin="0,8,0,0" Opacity="0.75" />
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                <Button Margin="0,0,8,0" Padding="12,6" Command="{Binding CancelCommand}" Content="{Binding CancelButtonLabel}" />
                <Button Padding="12,6" Command="{Binding ClearLogCommand}" Content="{Binding ClearLogButtonLabel}" />
            </StackPanel>
        </Grid>

        <TextBlock Grid.Row="1" Margin="0,12,0,10" Text="{Binding StatusMessage}" FontWeight="SemiBold" />

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding Actions}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Padding="0"
                                Margin="0,0,0,8"
                                Background="Transparent"
                                BorderThickness="0"
                                HorizontalContentAlignment="Stretch"
                                VerticalContentAlignment="Stretch"
                                Command="{Binding DataContext.RunCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                CommandParameter="{Binding}">
                            <ui:Card Padding="14">
                                <StackPanel>
                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="15" />
                                    <TextBlock Text="{Binding Description}" TextWrapping="Wrap" Margin="0,4,0,8" Opacity="0.9" />
                                    <TextBlock Text="{Binding DataContext.RunButtonLabel, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                               FontWeight="SemiBold"
                                               Opacity="0.85" />
                                </StackPanel>
                            </ui:Card>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <ui:Card Grid.Row="3" Margin="0,10,0,0" Padding="14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Text="{Binding ExecutionLogTitle}" FontWeight="SemiBold" FontSize="16" />
                <TextBlock Grid.Row="1" Margin="0,6,0,2" Text="{Binding SelectedActionTitle}" Opacity="0.85" />
                <TextBlock Grid.Row="2" Margin="0,0,0,10" Text="{Binding LastExitCodeLabel}" Opacity="0.75" />
                <ProgressBar Grid.Row="3" Height="8" Minimum="0" Maximum="100"
                             Value="{Binding ProgressValue}"
                             IsIndeterminate="{Binding IsProgressIndeterminate}" />
                <ScrollViewer Grid.Row="4" Margin="0,10,0,0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <TextBlock Text="{Binding Output}" FontFamily="Consolas" TextWrapping="Wrap" />
                </ScrollViewer>
            </Grid>
        </ui:Card>
    </Grid>
</UserControl>
